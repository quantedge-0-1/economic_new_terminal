# Economic News Terminal — Environment Variables
# Copy to backend/.env and fill in your API keys

APP_NAME=Economic News Terminal
ENVIRONMENT=development
DEBUG=false

# Database (SQLite — local file, no setup required)
DATABASE_URL=sqlite+aiosqlite:///./economic_terminal.db

# FRED API (free) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Twelve Data API (free tier) — https://twelvedata.com
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# Polygon.io — https://polygon.io
POLYGON_API_KEY=your_polygon_api_key_here

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...your_key_here

# AI Model — claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
AI_MODEL=claude-opus-4-8
AI_MAX_TOKENS=200
